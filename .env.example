# ==========================================
# Image Compressor Configuration
# ==========================================

# Application
APP_NAME=Image Compressor
APP_ENV=development
DEBUG=True

# Server
HOST=127.0.0.1
PORT=8000

# Image Compression
DEFAULT_IMAGE_QUALITY=80
MAX_UPLOAD_SIZE_MB=20

# Temporary Storage
TEMP_UPLOAD_DIR=app/temp/uploads
TEMP_OUTPUT_DIR=app/temp/compressed

# Logging
LOG_LEVEL=INFO
